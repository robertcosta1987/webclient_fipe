# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# provisioning state — contains the SQL admin password
.azure-provision.state

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.creds
scripts/*.local.json

# Customer API deliverables — contain a live API key, never commit
docs/Placas360-API-FIPE*.html
docs/Placas360-API-FIPE*.pdf
