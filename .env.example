# --- DB ---
# ADO.NET-style connection string for Azure SQL.
# Parser in scripts/migrate.ts + src/lib/db/pool.ts handles this format.
# The SQL server is provisioned via scripts/provision-azure.sh (or the
# az commands in README.md).
DATABASE_URL="Server=tcp:<your-server>.database.windows.net,1433;Initial Catalog=carros_ativos_db;Persist Security Info=False;User ID=dadocaradmin;Password=<strong-password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"

# --- Platform API ---
# Today: direct route to the Function App with a function key. When APIM
# products + subscriptions land (next-steps/001), swap to the APIM gateway
# URL and use Ocp-Apim-Subscription-Key in src/lib/platform/client.ts.
DADOCAR_API_URL="https://dadocar-dev-func-enrich-brs.azurewebsites.net"
DADOCAR_API_KEY="<function-key>"

# --- Pricing API (KBB / Molicar via services/pricing-function) ---
# PRICING_API_APP_ID is the Azure Function App resource NAME (no protocol,
# no .azurewebsites.net suffix); src/lib/pricing/client.ts expands it to
# "https://<APP_ID>.azurewebsites.net/api".
# A full https:// URL is also accepted and used verbatim — handy for local
# Functions Core Tools at "http://localhost:7072/api".
PRICING_API_APP_ID="dadocar-dev-pricing"
PRICING_API_KEY="<function-key>"

# --- CheckTudo API (services/pricing-function-checktudo) ---
# Separate, independent Function App from the pricing one. Same convention:
# CHECKTUDO_API_APP_ID is the Azure Function App resource NAME (expands to
# "https://<APP_ID>.azurewebsites.net/api"), or a full https:// URL verbatim
# (e.g. "http://localhost:7073/api" for local Functions Core Tools).
CHECKTUDO_API_APP_ID="dadocar-dev-func-checktudo-brs"
CHECKTUDO_API_KEY="<function-key>"

# --- App authentication ---
# Secret for signing session cookies. Generate: node -e "console.log(require(\047crypto\047).randomBytes(48).toString(\047base64url\047))"
AUTH_SECRET="<random-secret>"

# --- Recall analysis (item: "Veículo Listado Afetado?") ---
# Anthropic API key; the CheckTudo recall check calls Claude to compare the
# chassi against affected ranges. Without it the field shows "Indisponível".
ANTHROPIC_API_KEY="<anthropic-api-key>"
