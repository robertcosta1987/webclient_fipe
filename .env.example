# --- DB ---
# ADO.NET-style connection string for Azure SQL.
# Parser in scripts/migrate.ts + src/lib/db/pool.ts handles this format.
# The SQL server is provisioned via scripts/provision-azure.sh (or the
# az commands in README.md).
DATABASE_URL="Server=tcp:<your-server>.database.windows.net,1433;Initial Catalog=carros_ativos_db;Persist Security Info=False;User ID=dadocaradmin;Password=<strong-password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"

# --- Platform API ---
# Today: direct route to the Function App with a function key. When APIM
# products + subscriptions land (next-steps/001), swap to the APIM gateway
# URL and use Ocp-Apim-Subscription-Key in src/lib/platform/client.ts.
DADOCAR_API_URL="https://dadocar-dev-func-enrich-brs.azurewebsites.net"
DADOCAR_API_KEY="<function-key>"
